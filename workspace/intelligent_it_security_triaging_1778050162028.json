      "position": {
        "x": 400,
        "y": 250
      },
      "data": {
        "label": "Analyze Ticket - SOC Analyst",
        "type": "tool_generic_llm",
        "config": {
          "prompt": "You are a Level 1 SOC Analyst. Analyze the incoming helpdesk ticket to determine the 'severity' (Normal or Critical based on blast radius) and 'issue category' (e.g., Password Reset, Lost Device, System Outage). Output a structured JSON with 'severity' and 'issue category'."
        },
        "status": "idle"
      },
      "selected": true,
      "measured": {
        "width": 273,
        "height": 105
      }
    },
    {
      "id": "logic_condition_1778050148452_hfhjs",
      "type": "logic_condition",
      "position": {
        "x": 400,
        "y": 400
      },
      "data": {
        "label": "Route based on Severity and Category",
        "type": "logic_condition",
        "config": {
          "conditions": [
            {
              "target": "queue_ticket",
              "condition": "severity == 'Normal' and issue_category != 'Lost Device'"
            },
            {
              "target": "security_alert",
              "condition": "issue_category == 'Lost Device' or severity == 'Critical'"
            },
            {
              "target": "emergency_alert",
              "condition": "severity == 'Critical' and issue_category == 'System Outage'"
            }
          ]
        },
        "status": "idle"
      },
      "selected": true,
      "measured": {
        "width": 335,
        "height": 105
      }
    },
